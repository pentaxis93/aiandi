---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemePicker from './ThemePicker.astro';
---

<header class="bg-background border-b-2 border-accent/30 px-6 py-4">
	<nav class="max-w-6xl mx-auto flex items-center justify-between">
		<h2 class="m-0 text-2xl font-heading">
			<a 
				href="/" 
				class="text-text-primary no-underline hover:text-accent transition-colors duration-normal"
			>
				{SITE_TITLE}
			</a>
		</h2>
		
		<div class="hidden md:flex items-center gap-8">
			<div class="flex items-center gap-6">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/blog">Blog</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</div>
			
			<div class="flex items-center">
				<ThemePicker />
			</div>
		</div>
		
		<!-- Mobile: Just show theme picker -->
		<div class="md:hidden">
			<ThemePicker />
		</div>
	</nav>
</header>
